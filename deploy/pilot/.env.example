# Copy to deploy/pilot/.env and set real values. DO NOT commit .env.
# Only API keys live here; signing keys are PEM files under ./secrets (generated
# by generate_pilot_config.py) and are mounted, never placed in environment vars.

# Agent API key (X-API-Key) — propose / verify / execute.
MCC_GATEWAY_API_KEY=change-me-agent-key

# Operator API key (X-Operator-Key) — approve / deny / revoke / trust admin.
# Leave empty to disable ALL operator actions (fail-closed).
MCC_GATEWAY_OPERATOR_API_KEY=change-me-operator-key

# Enforced egress proxy: agent X-API-Key (and the reference agent uses the same).
MCC_EGRESS_API_KEY=change-me-egress-key
# Operator key for egress ESCALATE approvals (empty disables them, fail-closed).
MCC_EGRESS_OPERATOR_API_KEY=change-me-egress-operator-key

# Credential references (optional). "none" disables; "env" reads raw values from
# the env vars named in MCC_EGRESS_CREDENTIAL_CONFIG (a secret-free JSON mapping).
# MCC_EGRESS_CREDENTIAL_PROVIDER=env
# MCC_EGRESS_CREDENTIAL_CONFIG=/secrets/credentials.json
# Raw secret VALUES go here (git-ignored .env), referenced by name from the config:
# MCC_EGRESS_CRED_EXAMPLE_API=Bearer change-me
# MCC_EGRESS_MTLS_CERT=/secrets/client.crt
# MCC_EGRESS_MTLS_KEY=/secrets/client.key
# MCC_EGRESS_CA_BUNDLE=/secrets/ca.pem

# Optional: per-operation Redis timeouts (defaults are conservative).
# MCC_REDIS_OP_TIMEOUT_SECONDS=0.5
# MCC_REDIS_CONNECT_TIMEOUT_SECONDS=1.0
