# Example configuration for the MCC-Core Pilot v0.1 containerized stack.
#
# Copy to deploy/pilot/.env.pilot and adjust as needed:
#   cp deploy/pilot/.env.pilot.example deploy/pilot/.env.pilot
#
# These are NON-SECRET pilot defaults. Do NOT commit real secrets, signing keys,
# or production credentials. The gateway fails closed when a selected Redis
# backend has no MCC_REDIS_URL (no silent in-memory fallback).

# --- API keys for the governed gateway (pilot values; rotate for any real use) ---
MCC_EGRESS_API_KEY=agent-key
MCC_EGRESS_OPERATOR_API_KEY=op-key

# --- which identity holds the standing mandate ---
MCC_EGRESS_EGRESS_ACTOR_MANDATE=agent/crm

# --- destination policy (the external pilot API) ---
MCC_EGRESS_ALLOWED_HOSTS=pilot-api
MCC_EGRESS_ALLOWED_METHODS=get,post
MCC_EGRESS_MAX_AMOUNT=5000

# Pilot-only transport settings (the external API is plain HTTP on a private
# Docker network). For production, require HTTPS and disable these overrides.
MCC_EGRESS_ALLOW_PRIVATE=true
MCC_EGRESS_REQUIRE_HTTPS=false
MCC_EGRESS_ALLOW_HTTP=true

# --- Redis-backed state (required; fail-closed if unreachable) ---
MCC_REDIS_URL=redis://redis:6379/0
MCC_NONCE_BACKEND=redis
MCC_IDEMPOTENCY_BACKEND=redis
MCC_VELOCITY_BACKEND=redis
MCC_APPROVAL_BACKEND=redis
